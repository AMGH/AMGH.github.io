---
const isEn = Astro.url.pathname.includes('/en/');
---
<footer class="footer">
  <p>&copy; 2026 {isEn ? 'A Mini Game Hub' : '一个迷你游戏中心'}</p>
  <p class="operator">
    {isEn ? 'Operator' : '运营者'}: <strong>{isEn ? 'YiZhiMengXin65535' : '一只萌新65535'}</strong>
  </p>
</footer>
<style>
  .footer {
    text-align: center;
    padding: 2rem 0;
    margin-top: 3rem;
    border-top: 1px solid #ddd;
    color: #666;
    font-size: 0.85rem;
  }
  .operator { color: #2c3e50; font-weight: 500; }
</style>