---
import Footer from '../components/Footer.astro';
import LangSwitcher from '../components/LangSwitcher.astro';

const { title } = Astro.props;
const lang = Astro.url.pathname.includes('/en/') ? 'en' : 'zh'; 
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={lang === 'zh' ? '一个迷你游戏中心' : 'A Mini Game Hub'} />
    
    <link rel="alternate" hreflang="zh" href={new URL('/zh/', Astro.site).href} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site).href} />
  </head>
  <body>
    <header>
      <h1>{lang === 'zh' ? '一个迷你游戏中心' : 'A Mini Game Hub'}</h1>
      <LangSwitcher />
    </header>
    
    <main>
      <slot />
    </main>
    
    <Footer />
  </body>
</html>
<style>
  body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; line-height: 1.6; }
  header { text-align: center; margin-bottom: 2rem; }
</style>