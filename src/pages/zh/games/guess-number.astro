---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="猜数字 | 一个迷你游戏中心">
  <a href="/zh/" class="back-link">&larr; 返回大厅</a>
  <div class="game-panel">
    <h2>🎲 猜数字 <span class="badge">1-100</span></h2>
    <p id="message" class="msg">我已经想好了一个数字。你能猜中吗？</p>
    
    <div class="input-group">
      <input type="number" id="guessInput" min="1" max="100" placeholder="?" />
      <button id="submitBtn">确认</button>
    </div>
    
    <div class="stats">
      <div class="stat-item">
        <span class="stat-label">尝试次数</span>
        <span id="attempts" class="stat-value">0</span>
      </div>
    </div>
  </div>

  <!-- 结算弹窗 -->
  <div id="resultModal" class="modal-overlay">
    <div class="modal-content">
      <h3 class="modal-title">游戏结算</h3>
      <div class="rank-badge">S</div>
      <p class="rank-desc">天才直觉！</p>
      <p class="result-stats"></p>
      <button id="restartBtn" class="restart-btn">再玩一次</button>
    </div>
  </div>
</Layout>

<script>
  let target = Math.floor(Math.random() * 100) + 1;
  let attempts = 0;
  const input = document.getElementById('guessInput');
  const btn = document.getElementById('submitBtn');
  const msg = document.getElementById('message');
  const attText = document.getElementById('attempts');
  const modal = document.getElementById('resultModal');
  const restartBtn = document.getElementById('restartBtn');

  const showResult = () => {
    let rank, desc, rankClass;
    if (attempts <= 3) { rank = 'S'; desc = '天才直觉！'; rankClass = 'rank-S'; }
    else if (attempts <= 5) { rank = 'A'; desc = '逻辑大师！'; rankClass = 'rank-A'; }
    else if (attempts <= 7) { rank = 'B'; desc = '表现不错！'; rankClass = 'rank-B'; }
    else if (attempts <= 9) { rank = 'C'; desc = '勉强及格。'; rankClass = 'rank-C'; }
    else { rank = 'D'; desc = '再接再厉！'; rankClass = 'rank-D'; }

    modal.querySelector('.rank-badge').textContent = rank;
    modal.querySelector('.rank-badge').className = `rank-badge ${rankClass}`;
    modal.querySelector('.rank-desc').textContent = desc;
    modal.querySelector('.result-stats').textContent = `总共尝试: ${attempts} 次`;
    
    setTimeout(() => modal.classList.add('show'), 300); // 延迟弹出，更有仪式感
  };

  const restartGame = () => {
    target = Math.floor(Math.random() * 100) + 1;
    attempts = 0;
    attText.textContent = '0';
    msg.textContent = '我已经想好了一个数字。你能猜中吗？';
    msg.style.color = 'var(--text-primary)';
    input.value = '';
    input.disabled = false;
    btn.disabled = false;
    btn.textContent = '确认';
    modal.classList.remove('show');
    input.focus();
  };

  const checkGuess = () => {
    const val = parseInt(input.value);
    if (isNaN(val) || val < 1 || val > 100) {
      msg.textContent = '请输入1到100之间的有效数字！';
      msg.style.color = 'var(--danger)';
      input.classList.add('shake');
      setTimeout(() => input.classList.remove('shake'), 500);
      return;
    }
    attempts++;
    attText.textContent = attempts;
    
    if (val === target) {
      msg.textContent = `🎉 恭喜你，猜中了！`;
      msg.style.color = 'var(--success)';
      btn.disabled = true; input.disabled = true;
      btn.textContent = '游戏结束';
      showResult();
    } else if (val < target) {
      msg.textContent = '📈 太小了，再往大猜一点！';
      msg.style.color = 'var(--warning)';
    } else {
      msg.textContent = '📉 太大了，往小猜一点！';
      msg.style.color = 'var(--warning)';
    }
  };

  btn.addEventListener('click', checkGuess);
  input.addEventListener('keypress', (e) => { if(e.key === 'Enter') checkGuess(); });
  restartBtn.addEventListener('click', restartGame);
</script>

<style>
  .game-panel {
    background: var(--surface-color); backdrop-filter: blur(12px);
    padding: 3rem 2rem; border-radius: var(--radius); text-align: center;
    border: 1px solid rgba(255,255,255,0.1); max-width: 500px; margin: 0 auto;
  }
  h2 { font-size: 2rem; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: center; gap: 1rem; }
  .badge { font-size: 0.8rem; background: rgba(56, 189, 248, 0.2); color: var(--accent); padding: 0.25rem 0.75rem; border-radius: 99px; font-weight: 600; }
  .msg { font-size: 1.2rem; min-height: 2rem; font-weight: 500; margin-bottom: 2rem; transition: color 0.3s; }
  
  .input-group { display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; }
  input {
    padding: 0.8rem 1rem; font-size: 1.2rem; width: 120px; text-align: center;
    background: rgba(0,0,0,0.2); border: 2px solid rgba(255,255,255,0.1); border-radius: 12px;
    color: white; font-weight: 600; outline: none; transition: border-color 0.2s;
  }
  input:focus { border-color: var(--accent); }
  button {
    padding: 0 1.5rem; font-size: 1rem; background: var(--accent); color: var(--bg-color);
    border: none; border-radius: 12px; cursor: pointer; font-weight: 700; transition: opacity 0.2s;
  }
  button:disabled { opacity: 0.5; cursor: not-allowed; }
  
  .stats { display: flex; justify-content: center; gap: 2rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; }
  .stat-item { display: flex; flex-direction: column; }
  .stat-label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
  .stat-value { font-size: 1.5rem; font-weight: 800; color: var(--accent); }

  /* 结算弹窗样式 */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px);
    display: flex; align-items: center; justify-content: center; z-index: 1000;
    opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
  }
  .modal-overlay.show { opacity: 1; pointer-events: all; }
  
  .modal-content {
    background: var(--surface-color); border: 1px solid rgba(255,255,255,0.15);
    padding: 3rem 2rem; border-radius: var(--radius); text-align: center;
    transform: scale(0.8) translateY(20px); transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    max-width: 360px; width: 90%; box-shadow: 0 25px 50px rgba(0,0,0,0.5);
  }
  .modal-overlay.show .modal-content { transform: scale(1) translateY(0); }
  
  .modal-title { font-size: 1.2rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
  
  .rank-badge {
    font-size: 6rem; font-weight: 900; line-height: 1; margin: 1rem 0;
    text-shadow: 0 0 30px currentColor; animation: pulse 2s infinite;
  }
  @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
  
  .rank-S { color: #fbbf24; } /* 金色 */
  .rank-A { color: #a855f7; } /* 紫色 */
  .rank-B { color: #38bdf8; } /* 蓝色 */
  .rank-C { color: #10b981; } /* 绿色 */
  .rank-D { color: #94a3b8; } /* 灰色 */
  
  .rank-desc { font-size: 1.25rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
  .result-stats { color: var(--text-secondary); margin-bottom: 2rem; }
  
  .restart-btn {
    padding: 0.8rem 2rem; font-size: 1rem; background: var(--accent); color: var(--bg-color);
    border: none; border-radius: 12px; cursor: pointer; font-weight: 700; transition: transform 0.2s, opacity 0.2s;
  }
  .restart-btn:hover { transform: translateY(-2px); opacity: 0.9; }
</style>