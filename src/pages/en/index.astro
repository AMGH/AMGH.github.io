---
import Layout from '../../layouts/Layout.astro';

const games = [
  { title: '🎲 Guess Number', desc: 'Classic logic puzzle. Challenge your intuition!', link: '/en/games/guess-number', color: '#38bdf8' },
  { title: '⚡ Reaction Test', desc: 'Test your neural reflex speed.', link: '/en/games/reaction-test', color: '#f43f5e' }
];

const lb = {
  title: '🏆 Local Records',
  guessLabel: 'Guess Number (Best)', // 精简文案
  reactLabel: 'Reaction Test (Fastest)', // 精简文案
  hint: '* Data stored locally in your browser'
};
---
<Layout title="A Mini Game Hub | Home">
  <section class="hero">
    <h1 class="gradient-text">Play. Relax. Repeat.</h1>
    <p class="subtitle">An indie game hub built by <strong>YiZhiMengXin65535</strong></p>
  </section>

  <section class="leaderboard">
    <h2 class="lb-title">{lb.title}</h2>
    <div class="lb-grid">
      <div class="lb-card">
        <span class="lb-icon">🎲</span>
        <div class="lb-info">
          <span class="lb-label">{lb.guessLabel}</span>
          <span class="lb-value" id="rec-guess">--</span>
        </div>
      </div>
      <div class="lb-card">
        <span class="lb-icon">⚡</span>
        <div class="lb-info">
          <span class="lb-label">{lb.reactLabel}</span>
          <span class="lb-value" id="rec-react">--</span>
        </div>
      </div>
    </div>
    <p class="lb-hint">{lb.hint}</p>
  </section>

  <section class="game-grid">
    {games.map((game, i) => (
      <a href={game.link} class="game-card" style={`--accent-color: ${game.color}; animation-delay: ${i * 0.1}s`}>
        <div class="card-icon">{game.title.split(' ')[0]}</div>
        <div class="card-content">
          <h3>{game.title.substring(game.title.indexOf(' ') + 1)}</h3>
          <p>{game.desc}</p>
        </div>
        <div class="card-arrow">&rarr;</div>
      </a>
    ))}
  </section>
</Layout>

<script>
  document.querySelectorAll('.game-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  const records = JSON.parse(localStorage.getItem('amgh_hub_records') || '{}');
  if (records.guess) {
    document.getElementById('rec-guess').textContent = `${records.guess.best} tries (${records.guess.date})`;
  }
  if (records.react) {
    document.getElementById('rec-react').textContent = `${records.react.best} ms (${records.react.date})`;
  }
</script>

<style>
  .hero { text-align: center; margin-bottom: 3rem; }
  .gradient-text {
    font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800;
    background: linear-gradient(135deg, #38bdf8 0%, #f43f5e 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 1rem; letter-spacing: -0.03em; /* 英文大标题收紧字间距 */
  }
  .subtitle { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; }

  .leaderboard { margin-bottom: 3rem; text-align: center; }
  .lb-title { font-size: 1.5rem; margin-bottom: 1.5rem; color: var(--text-primary); letter-spacing: -0.02em; }
  .lb-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; max-width: 600px; margin: 0 auto; }
  .lb-card {
    display: flex; align-items: center; gap: 1rem; padding: 1.25rem;
    background: var(--surface-color); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-align: left;
  }
  .lb-icon { font-size: 2rem; }
  .lb-info { display: flex; flex-direction: column; }
  /* 英文排版优化：全大写 + 增加字间距 + 缩小字号 */
  .lb-label { 
    font-size: 0.7rem; color: var(--text-secondary); 
    text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 0.25rem;
  }
  .lb-value { font-size: 1.1rem; font-weight: 700; color: var(--accent); }
  .lb-hint { font-size: 0.75rem; color: var(--text-secondary); margin-top: 1rem; opacity: 0.6; font-style: italic; }
  
  html.strict-mode .lb-card { background: #111 !important; border: 1px solid #333 !important; border-radius: 0 !important; }

  .game-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .game-card {
    position: relative; background: var(--surface-color); backdrop-filter: blur(10px);
    border-radius: var(--radius); padding: 2rem; text-decoration: none; color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.1); overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s;
    display: flex; flex-direction: column; gap: 1.5rem;
    opacity: 0; animation: fadeIn 0.6s ease-out forwards;
  }
  .game-card::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255, 255, 255, 0.06), transparent 40%);
    opacity: 0; transition: opacity 0.3s; pointer-events: none;
  }
  .game-card:hover { transform: translateY(-8px); border-color: var(--accent-color, #38bdf8); }
  .game-card:hover::before { opacity: 1; }
  .card-icon {
    font-size: 2rem; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center;
    background: rgba(255, 255, 255, 0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);
  }
  /* 英文排版优化：增加行高 */
  .card-content h3 { font-size: 1.35rem; margin-bottom: 0.5rem; font-weight: 700; line-height: 1.3; letter-spacing: -0.01em; }
  .card-content p { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; }
  .card-arrow { margin-top: auto; font-size: 1.5rem; color: var(--accent-color, #38bdf8); transition: transform 0.3s; }
  .game-card:hover .card-arrow { transform: translateX(10px); }
</style>